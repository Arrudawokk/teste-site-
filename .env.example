# URL pública canônica, com HTTPS e sem barra final.
NEXT_PUBLIC_SITE_URL=

# Mercado Pago. Preencha com credenciais do mesmo ambiente (teste ou produção).
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Persistência transacional. Use a URL com pooler fornecida pelo seu Postgres.
DATABASE_URL=

# Segredo aleatório com pelo menos 32 caracteres para links de download temporários.
DELIVERY_TOKEN_SECRET=

# Origem privada do arquivo do produto. A autorização é opcional e deve
# conter o valor completo do header, por exemplo: Bearer token-do-storage.
PRODUCT_TRAFEGO_DOWNLOAD_URL=
PRODUCT_TRAFEGO_DOWNLOAD_AUTHORIZATION=

# Analytics opcionais. Mantenha vazios para desativar cada integração.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Links sociais opcionais.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_YOUTUBE_URL=
