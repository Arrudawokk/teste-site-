# URL pública canônica, com HTTPS e sem barra final. Na Vercel, a aplicação
# usa VERCEL_PROJECT_PRODUCTION_URL automaticamente enquanto este valor estiver vazio.
NEXT_PUBLIC_SITE_URL=

# Stripe. As quatro variáveis devem pertencer ao mesmo modo (teste ou produção).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PRICE_ID=

# Persistência transacional. Use a URL com pooler fornecida pelo seu Postgres.
DATABASE_URL=

# Painel administrativo. Gere o hash bcrypt (custo 12) com `npm run admin:hash-password`.
# Nunca armazene a senha em texto puro.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Segredo aleatório com pelo menos 32 caracteres para links de download temporários.
DELIVERY_TOKEN_SECRET=

# Cloudflare R2 privado. Gere uma credencial S3 com leitura no bucket de produtos.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Opcional para outros ativos. Downloads privados nunca utilizam esta URL.
R2_PUBLIC_URL=

# Analytics opcionais. Mantenha vazios para desativar cada integração.
# Se o GTM encaminhar eventos para o GA4, deixe o ID direto do GA4 vazio para
# evitar que o mesmo evento chegue duas vezes à mesma propriedade.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Links sociais opcionais.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_YOUTUBE_URL=
